#!/usr/bin/env bash
# run_after_10-hk-install.sh.tmpl
# Install hk git hooks with mise integration.
# Uses run_after (not run_once_after) to ensure hooks stay fresh after hk upgrades.

{{ if .is_ephemeral -}}
# Skip hk hook installation in ephemeral/CI environments
exit 0
{{ end -}}

set -euo pipefail

# chezmoi runs scripts from $HOME — cd to source dir where hk.pkl lives
cd "{{ .chezmoi.sourceDir }}/.."

# Ensure mise shims are in PATH
export PATH="{{ .chezmoi.homeDir }}/.local/share/mise/shims:{{ .chezmoi.homeDir }}/.local/bin:$PATH"

if command -v hk >/dev/null 2>&1; then
    echo "Installing hk git hooks with mise integration..."
    hk install --mise
else
    echo "Warning: hk not found in PATH, skipping hook installation" >&2
fi
