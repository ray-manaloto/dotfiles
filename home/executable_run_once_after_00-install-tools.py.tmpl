#!/usr/bin/env python3
import subprocess
import sys
import os
from pathlib import Path

def main():
    """
    Chezmoi lifecycle script to install tools using the dotfiles-setup Python library.
    This script is rendered by Chezmoi and executed after files are applied.
    """
    # Enforce Mise strictness
    os.environ["MISE_STRICT"] = "1"

    # The source directory of chezmoi is provided by the template variable
    source_dir = Path("{{ .chezmoi.sourceDir }}")
    
    # The Python library is located in the 'python' directory at the root of the repo.
    # Since 'home' is the chezmoi root (containing .chezmoiroot), the repo root is the parent.
    python_project_dir = source_dir.parent / "python"
    
    # Ensure the python project directory exists
    if not python_project_dir.exists():
        print(f"Error: Python project directory not found at {python_project_dir}", file=sys.stderr)
        sys.exit(1)
    
    # Ensure ~/.local/bin and mise shims are in PATH for mise and uv
    home = Path.home()
    local_bin = home / ".local" / "bin"
    mise_shims = home / ".local" / "share" / "mise" / "shims"
    
    current_path = os.environ.get("PATH", "")
    if str(local_bin) not in current_path:
        os.environ["PATH"] = f"{local_bin}:{current_path}"
    if str(mise_shims) not in os.environ.get("PATH", ""):
        os.environ["PATH"] = f"{mise_shims}:{os.environ['PATH']}"
            
    def run_dotfiles_setup(command, args=None):
        """Helper to run dotfiles-setup commands via uv or mise."""
        cmd = ["uv", "run", "--project", str(python_project_dir), "dotfiles-setup", command]
        if args:
            cmd.extend(args)
            
        try:
            # Attempt to run uv directly
            subprocess.run(cmd, check=True)
            return True
        except FileNotFoundError:
            # If uv is not in PATH, try to use mise to run it
            try:
                print(f"uv not found in PATH, attempting to run '{command}' via mise...", file=sys.stderr)
                mise_cmd = ["mise", "exec", "--"] + cmd
                subprocess.run(mise_cmd, check=True)
                return True
            except (subprocess.CalledProcessError, FileNotFoundError) as e:
                print(f"Error: 'uv' or 'mise' command not found or failed during '{command}'. {e}", file=sys.stderr)
                return False
        except subprocess.CalledProcessError as e:
            print(f"Error: dotfiles-setup {command} failed with exit code {e.returncode}", file=sys.stderr)
            return False

    # 1. Install tools
    print(f"Running dotfiles-setup install from {python_project_dir}...")
    if not run_dotfiles_setup("install"):
        sys.exit(1)
        
    # 2. AI Setup
    print(f"Running dotfiles-setup ai-setup from {python_project_dir}...")
    if not run_dotfiles_setup("ai-setup"):
        print("Warning: dotfiles-setup ai-setup failed to run.", file=sys.stderr)

    # 3. Audit environment
    print(f"Running dotfiles-setup audit from {python_project_dir}...")
    if not run_dotfiles_setup("audit"):
        print("Warning: dotfiles-setup audit reported issues or failed to run.", file=sys.stderr)

if __name__ == "__main__":
    main()
