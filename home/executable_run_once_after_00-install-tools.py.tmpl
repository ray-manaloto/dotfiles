#!/usr/bin/env python3
import subprocess
import sys
import os
from pathlib import Path

def main():
    """
    Chezmoi lifecycle script to install tools using the dotfiles-setup Python library.
    This script is rendered by Chezmoi and executed after files are applied.
    """
    # The source directory of chezmoi is provided by the template variable
    source_dir = Path("{{ .chezmoi.sourceDir }}")
    
    # The Python library is located in the 'python' directory at the root of the repo.
    # Since 'home' is the chezmoi root (containing .chezmoiroot), the repo root is the parent.
    python_project_dir = source_dir.parent / "python"
    
    # Ensure the python project directory exists
    if not python_project_dir.exists():
        print(f"Error: Python project directory not found at {python_project_dir}", file=sys.stderr)
        sys.exit(1)
    
    print(f"Running dotfiles-setup install from {python_project_dir}...")
    
    # Ensure ~/.local/bin and mise shims are in PATH for mise and uv
    home = Path.home()
    local_bin = home / ".local" / "bin"
    mise_shims = home / ".local" / "share" / "mise" / "shims"
    
    current_path = os.environ.get("PATH", "")
    if str(local_bin) not in current_path:
        os.environ["PATH"] = f"{local_bin}:{current_path}"
    if str(mise_shims) not in os.environ.get("PATH", ""):
        os.environ["PATH"] = f"{mise_shims}:{os.environ['PATH']}"
            
    # Use 'uv run' to execute the 'dotfiles-setup' library.
    # We use --project to specify the directory containing pyproject.toml.
    # The 'install' command triggers mise and pixi installations.
    try:
        # Attempt to run uv directly
        subprocess.run(
            ["uv", "run", "--project", str(python_project_dir), "dotfiles-setup", "install"],
            check=True
        )
    except FileNotFoundError:
        # If uv is not in PATH, try to use mise to run it
        try:
            print("uv not found in PATH, attempting to run via mise...", file=sys.stderr)
            subprocess.run(
                ["mise", "exec", "--", "uv", "run", "--project", str(python_project_dir), "dotfiles-setup", "install"],
                check=True
            )
        except (subprocess.CalledProcessError, FileNotFoundError) as e:
            print(f"Error: 'uv' or 'mise' command not found or failed. {e}", file=sys.stderr)
            sys.exit(1)
    except subprocess.CalledProcessError as e:
        print(f"Error: dotfiles-setup install failed with exit code {e.returncode}", file=sys.stderr)
        sys.exit(e.returncode)

if __name__ == "__main__":
    main()
