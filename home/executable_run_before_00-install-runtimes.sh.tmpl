#!/usr/bin/env bash
# run_before_00-install-runtimes.sh.tmpl
# This script is rendered by Chezmoi to ensure absolute latest versions
# are used during the bootstrap phase.

echo "Bootstrap: Ensuring Python and UV are available via Mise..."

# Ensure ~/.local/bin is in PATH for the standalone Mise
export PATH="$HOME/.local/bin:$PATH"

# Trust the current directory's configuration
mise trust

# Trigger the declarative install from config.toml
# This ensures foundations (Python, UV, Pixi) are present for subsequent hooks
mise install
