# .profile - Managed by chezmoi

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
        . "$HOME/.bashrc"
    fi
fi

# Ensure ~/.local/bin is in PATH for non-bash login shells
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# Load Mise shims for non-interactive login shells
# Uses MISE_DATA_DIR if set (devcontainer: /opt/mise), falls back to default
MISE_SHIMS="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims"
if [ -d "$MISE_SHIMS" ]; then
  export PATH="$MISE_SHIMS:$PATH"
fi
