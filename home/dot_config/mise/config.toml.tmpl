[tools]
# Python comes from Mise's registries
python = "3.14.3"
chezmoi = "2.70.0"
uv = "0.11.2"
pixi = "0.66.0"
bun = "1.3.11"
node = "25.8.2"
go = "1.26.1"
rust = "1.94.1"
zig = "0.15.2"
bats = "1.13.0"
fzf = "0.70.0"
ripgrep = "15.1.0"
fd = "10.4.2"
bat = "0.26.1"
# Git hooks & linting tools
hk = "1.39.0"
pkl = "0.31.1"
hadolint = "2.14.0"
shellcheck = "0.11.0"
shfmt = "3.13.0"
taplo = "0.10.0"
actionlint = "1.7.11"
typos = "1.44.0"
yamllint = "1.38.0"
yamlfmt = "0.18.0"
yq = "4.48.0"
ghalint = "1.0.0"
jq = "1.8.1"
# AI CLIs
"npm:@google/gemini-cli" = "0.35.3"
"npm:@openai/codex" = "0.117.0"

[settings]
experimental = true
auto_install = true
asdf_compat = true
lockfile = true

[settings.status]
show_tools = true
missing_tools = "always"

[env]
# Enforce system toolchains for low-level builds
CC = "gcc"
CXX = "g++"
# hk: use built-in Rust pkl evaluator (no pkl CLI dependency)
HK_PKL_BACKEND = "pklr"
# hk: enable mise integration
HK_MISE = "1"

[tasks.lint]
description = "Run all linters via hk"
run = "hk run pre-commit --all"

[tasks.test]
description = "Run Python test suite"
run = "uv run pytest tests/ -x -q"

[tasks.check]
description = "Run full quality check (lint + test)"
depends = ["lint", "test"]

[tasks.outdated]
description = "Check for outdated tool versions"
run = "mise outdated"

[tasks.fmt]
description = "Auto-fix formatting issues"
run = "hk fix"
