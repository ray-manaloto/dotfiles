{
  "name": "dotfiles-devcontainer",
  "image": "ghcr.io/ray-manaloto/dotfiles-devcontainer:dev",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "init": true,
  "overrideCommand": true,
  "containerEnv": {
    "DEVCONTAINER": "true",
    "MISE_STRICT": "1"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/share/mise/shims"
  },
  "runArgs": [
    "--platform=linux/amd64"
  ],
  "mounts": [
    "type=volume,src=mise-home,target=/home/vscode/.local/share/mise",
    "type=volume,src=uv-cache,target=/home/vscode/.cache/uv",
    "type=volume,src=claude-home,target=/home/vscode/.claude",
    "type=volume,src=codex-home,target=/home/vscode/.codex",
    "type=volume,src=gemini-home,target=/home/vscode/.gemini",
    "type=volume,src=gh-config,target=/home/vscode/.config/gh",
    "type=bind,source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly"
  ],
  "postStartCommand": "mise install -y"
}
